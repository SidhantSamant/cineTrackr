{
    "expo": {
        "name": "Cine Trackr",
        "slug": "cine-trackr",
        "version": "1.0.0",
        "scheme": "cinetrackr",
        "orientation": "portrait",
        "icon": "./assets/icon.png",
        "userInterfaceStyle": "dark",
        "backgroundColor": "#121212",
        "splash": {
            "image": "./assets/splash.png",
            "resizeMode": "contain",
            "backgroundColor": "#121212"
        },
        "assetBundlePatterns": ["**/*"],
        "ios": {
            "supportsTablet": true,
            "bundleIdentifier": "com.sidhantsamant.cinetrackr",
            "infoPlist": {
                "ITSAppUsesNonExemptEncryption": false
            }
        },
        "android": {
            "adaptiveIcon": {
                "foregroundImage": "./assets/adaptive-icon.png",
                "backgroundColor": "#121212"
            },
            "package": "com.sidhantsamant.cinetrackr"
        },
        "web": {
            "bundler": "metro",
            "output": "static",
            "favicon": "./assets/favicon.png"
        },
        "plugins": [
            "expo-router",
            "expo-web-browser",
            "expo-font",
            "@react-native-google-signin/google-signin",
            [
                "expo-splash-screen",
                {
                    "image": "./assets/icon.png",
                    "resizeMode": "contain",
                    "backgroundColor": "#121212"
                }
            ],
            [
                "expo-navigation-bar",
                {
                    "backgroundColor": "#121212",
                    "barStyle": "light"
                }
            ]
        ],
        "experiments": {
            "typedRoutes": true,
            "tsconfigPaths": true
        },
        "extra": {
            "router": {},
            "expo-navigation-bar": {
                "backgroundColor": "#121212",
                "barStyle": "light"
            },
            "eas": {
                "projectId": "2ec40610-3167-402d-bf67-42bbae510e62"
            }
        },
        "owner": "sidhantsamant",
        "runtimeVersion": {
            "policy": "appVersion"
        },
        "updates": {
            "url": "https://u.expo.dev/2ec40610-3167-402d-bf67-42bbae510e62"
        }
    }
}
